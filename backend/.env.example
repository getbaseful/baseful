# Baseful Environment Variables

# The public IP of this machine.
# Used as a fallback when no domain/explicit proxy host is configured.
PUBLIC_IP=localhost

# Legacy shared JWT secret.
# Keep this set during upgrades so existing issued session/proxy tokens keep validating.
JWT_SECRET=replace-me-with-a-secure-random-string-at-least-32-chars

# New separated signing secrets for fresh session and proxy tokens.
# Safe to leave blank on first boot if you are still migrating, but production should set them.
USER_JWT_SECRET=
PROXY_JWT_SECRET=

# Lifetime for newly issued proxy tokens.
PROXY_TOKEN_TTL=90d

# Database proxy listener configuration.
PROXY_PORT=6432

# Public hostname clients should use for the database proxy.
# For production, use a real DNS hostname with a valid TLS certificate.
PROXY_HOST=localhost

# Optional DNS hostname managed by the dashboard/Caddy flow.
DOMAIN_NAME=

# Docker Network Configuration
DOCKER_NETWORK=baseful-network

# ============================================
# Security Configuration
# ============================================

# TLS certificate paths inside the container.
# If DOMAIN_NAME is configured, Baseful can auto-detect the Caddy-managed certificate.
PROXY_CERT_FILE=
PROXY_KEY_FILE=

# Legacy TLS variable names from older releases.
# Keep blank unless you are migrating an older config by hand.
PROXY_TLS_CERT_FILE=
PROXY_TLS_KEY_FILE=

# Enable SSL/TLS termination on the proxy (legacy compatibility flag).
PROXY_SSL_ENABLED=false

# Path to Client CA file for mutual TLS authentication (optional)
PROXY_TLS_CA_FILE=

# Idle Connection Timeout
# Maximum time a connection can be idle before being closed
PROXY_IDLE_TIMEOUT=30m

# Query Timeout
# Maximum time a single query can execute before being cancelled
PROXY_QUERY_TIMEOUT=5m

# Enable Token Revocation Checking
PROXY_REVOCATION_CHECK=true

# Logging Configuration
PROXY_LOG_PATH=

# Maximum number of log entries to keep in memory
PROXY_MAX_LOG_ENTRIES=10000

# Basic public-proxy abuse protection defaults.
PROXY_MAX_CONNECTIONS=500
PROXY_MAX_CONNECTIONS_PER_IP=25
PROXY_CONNECTION_RATE_PER_MINUTE=120

# Debug reset endpoint is disabled by default in production.
ENABLE_UNSAFE_RESET_ADMIN=false

# Docker Network Configuration
DOCKER_NETWORK=baseful-network

# Application Configuration
APP_PORT=8080
GIN_MODE=release
